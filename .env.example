# Gemini API Key for AI document analysis
# No Vercel, adicione esta variável nas configurações do projeto (Environment Variables)
GEMINI_API_KEY=

# Configurações do Firebase (necessárias se for usar o seu próprio Firebase no Vercel)
# Se estiver usando o Firebase gerado pelo AI Studio, você precisará copiar os valores do firebase-applet-config.json
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=
